<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SGO – Painel Mecânico</title>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body class="app-layout tablet-mode"> 
  <div id="sidebar-overlay" class="sidebar-overlay"></div>

  <nav class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-logo">
        <div class="logo-icon">🔧</div>
        <div class="logo-text">SGO<div class="logo-subtitle">Gestão de Oficina</div></div>
      </div>
    </div>
    <ul class="sidebar-nav">
      <li class="nav-section-label">Mecânico</li>
      <li><a href="mecanico.html" class="active"><span class="nav-icon">👨‍🔧</span> Painel Mecânico</a></li>
      <li><a href="reparacoes.html"><span class="nav-icon">🔩</span> Reparações</a></li>
      <li><a href="viaturas.html"><span class="nav-icon">🚗</span> Viaturas</a></li>
      <li><a href="pecas.html"><span class="nav-icon">📦</span> Peças</a></li>
      <li><a href="logs.html"><span class="nav-icon">📋</span> Logs</a></li>
    </ul>
    <div class="sidebar-footer">
      <button class="btn btn-outline-danger btn-sm w-full" onclick="logout()">🚪 Sair</button>
    </div>
  </nav>

  <div class="main-content">
    <header class="page-header" style="position: relative;">
      
      <div class="page-header-left" style="display: flex; align-items: center; gap: 1rem;">
        <button id="btn-voltar-global" class="btn btn-secondary btn-sm" onclick="voltarGlobal()">⬅ Voltar</button>
        <h1 class="page-title" style="margin: 0;">👨‍🔧 Painel Mecânico</h1>
      </div>
      
      <div class="page-header-center header-user-name">
        <span id="top-user-name">Bem-vindo]</span>
      </div>

      <div class="page-header-actions" id="header-actions">
        <div class="theme-toggle" style="margin: 0; padding: 0;">
          <span class="theme-toggle-icon">☀️</span>
          <label class="theme-switch" title="Alternar tema">
            <input type="checkbox" class="theme-checkbox" aria-label="Alternar tema" checked>
            <span class="theme-slider"></span>
          </label>
          <span class="theme-toggle-icon">🌙</span>
        </div>
        <button class="btn btn-secondary" onclick="loadMyRepairs()">🔄 Atualizar</button>
      </div>
    </header>

    <main class="page-body">
      
      <div id="view-dashboard" class="view-section active">
        
        <div class="dashboard-kpi-row">
          <div class="kpi-card" id="kpi-card-1">
            <div class="kpi-icon" style="background: rgba(234, 179, 8, 0.1); color: #eab308;">⏳</div>
            <div class="kpi-info">
              <span class="kpi-label" id="kpi-label-1">Pendentes</span>
              <h3 class="kpi-value" id="kpi-pendentes">0</h3>
            </div>
          </div>
          <div class="kpi-card" id="kpi-card-2">
            <div class="kpi-icon" style="background: rgba(59, 130, 246, 0.1); color: #3b82f6;">🔧</div>
            <div class="kpi-info">
              <span class="kpi-label" id="kpi-label-2">Em Progresso</span>
              <h3 class="kpi-value" id="kpi-progresso">0</h3>
            </div>
          </div>
          <div class="kpi-card" id="kpi-card-3">
            <div class="kpi-icon" style="background: rgba(168, 85, 247, 0.1); color: #a855f7;">📦</div>
            <div class="kpi-info">
              <span class="kpi-label" id="kpi-label-3">Aguarda Peças</span>
              <h3 class="kpi-value" id="kpi-pecas">0</h3>
            </div>
          </div>
          <div class="kpi-card" id="kpi-card-4">
            <div class="kpi-icon" style="background: rgba(34, 197, 94, 0.1); color: #22c55e;">✅</div>
            <div class="kpi-info">
              <span class="kpi-label" id="kpi-label-4">Concluídos</span>
              <h3 class="kpi-value" id="kpi-concluidos">0</h3>
            </div>
          </div>
        </div>

        <div class="card table-card mt-2">
          <div class="card-header">
            <h2 class="card-title">📋 Fila de Trabalho</h2>
          </div>
          <div class="card-body p-0">
            <div class="table-wrapper">
              <table class="modern-table">
                <thead>
                  <tr>
                    <th>Matrícula</th>
                    <th>Veículo</th>
                    <th>Cliente</th>
                    <th>Data de Entrada</th>
                    <th>Estado</th>
                    <th>Ações</th>
                  </tr>
                </thead>
                <tbody id="repair-list">
                  <tr><td colspan="6"><div class="loading-overlay"><div class="spinner"></div></div></td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div id="view-details" class="view-section hidden">
        <div class="details-nav mb-2" style="margin-bottom: 1rem;">
          <button class="btn btn-secondary" onclick="backToDashboard()">⬅ Voltar à Fila de Trabalho</button>
        </div>
        <div id="details-content-wrapper">
          </div>
      </div>

    </main>
  </div>

  <div id="modal-op" class="modal-overlay" style="z-index: 1010;" role="dialog">
    <div class="modal modal-sm">
      <div class="modal-header"><h3 class="modal-title" id="modal-op-title">Nova Operação</h3><button class="modal-close" onclick="hideModal('modal-op')">✕</button></div>
      <form id="form-op" onsubmit="submitOperacao(event)">
        <div class="modal-body">
          <input type="hidden" id="op-id">
          <div class="form-group"><label>Descrição *</label><input type="text" id="op-descricao" required></div>
          <div class="form-row">
            <div class="form-group"><label>Tempo Estimado (min)</label><input type="number" id="op-tempo" min="1"></div>
          </div>
          <div class="form-group">
            <label>Estado da Operação</label>
            <select id="op-estado">
              <option value="PENDENTE">Pendente</option>
              <option value="EM_EXECUCAO">Em Execução</option>
              <option value="CONCLUIDA">Concluída</option>
            </select>
          </div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" onclick="hideModal('modal-op')">Cancelar</button><button type="submit" class="btn btn-primary">Guardar</button></div>
      </form>
    </div>
  </div>

  <div id="modal-requisitar" class="modal-overlay" style="z-index: 1010;" role="dialog">
    <div class="modal modal-sm">
      <div class="modal-header"><h3 class="modal-title">Confirmar Requisição</h3><button class="modal-close" onclick="hideModal('modal-requisitar')">✕</button></div>
      <form id="form-requisitar" onsubmit="submitRequisicao(event)">
        <div class="modal-body">
          <input type="hidden" id="req-peca-id">
          <p id="req-peca-desc" style="font-weight:600; margin-bottom:.5rem">—</p>
          <div class="form-group"><label>Quantidade *</label><input type="number" id="req-qty" required min="1" value="1"></div>
          <div class="form-group"><label>Observações</label><input type="text" id="req-obs" placeholder="Para esta reparação…"></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary" onclick="hideModal('modal-requisitar')">Cancelar</button><button type="submit" class="btn btn-primary">Confirmar</button></div>
      </form>
    </div>
  </div>

  <script src="js/utils.js"></script>
  <script src="js/api.js"></script>
  <script src="js/auth.js"></script>
  <script src="js/mecanico.js"></script>
</body>
</html>