'use strict';

const CHECKLIST_ITEMS = [
  'Verificação de óleo',
  'Verificação de travões',
  'Verificação de suspensão',
  'Verificação de pneus',
  'Diagnóstico eletrónico',
  'Verificação de luzes',
  'Verificação de fluidos',
  'Verificação de bateria',
];

let allRepairs      = [];
let currentRepair   = null;
let allPecas        = [];
let timerInterval   = null;
let timerSeconds    = 0;
let timerRunning    = false;
let currentOpId     = null; // operation being timed

document.addEventListener('DOMContentLoaded', async () => {
  if (!initProtectedPage(['MECHANIC', 'MANAGER'])) return;
  await loadMyRepairs();
});

/* ── Load mechanic's repairs ── */
async function loadMyRepairs() {
  const user = getCurrentUser();
  if (!user) return;
  const listEl   = document.getElementById('repair-list');
  const countEl  = document.getElementById('repair-count');
  if (!listEl) return;

  listEl.innerHTML = `<div class="loading-overlay"><div class="spinner"></div></div>`;

  try {
    const data = await api.getReparacoesMecanico(user.id);
    allRepairs  = (data || []).filter(r => ['PENDENTE', 'EM_PROGRESSO', 'EM_EXECUCAO', 'AGUARDA_PECAS'].includes(r.estado));
    if (countEl) countEl.textContent = allRepairs.length;
    renderRepairList();
  } catch (err) {
    listEl.innerHTML = `<div class="alert alert-danger"><span class="alert-icon">❌</span> ${escapeHtml(err.message)}</div>`;
  }
}

/* ── Render Repair List ── */
function renderRepairList() {
  const listEl = document.getElementById('repair-list');
  if (!listEl) return;
  
  if (!allRepairs.length) {
    listEl.innerHTML = `
      <div class="empty-state" style="padding:2rem 1rem">
        <div class="empty-icon">✅</div>
        <div class="empty-title">Sem reparações</div>
        <div class="empty-desc">Não tem reparações atribuídas de momento.</div>
      </div>`;
    return;
  }
  
  listEl.innerHTML = allRepairs.map(r => {
    const isActive = currentRepair?.id === r.id;
    
    // Buscar as propriedades planas enviadas pelo ReparacaoResponse.java
    const matricula = r.viaturaMatricula || '#' + r.id;
    const marcaModelo = `${r.viaturaMarca || ''} ${r.viaturaModelo || ''}`.trim() || '—';
    const clienteNome = r.clienteNome || '—';

    return `
      <div class="repair-item ${isActive ? 'active' : ''}" style="margin-bottom: 1rem; border: 1px solid var(--border-color); border-radius: var(--radius); padding: 1rem; cursor: default;">
        <div class="repair-item-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
          <strong class="repair-matricula" style="font-size: 1.1rem; color: var(--text-color);">${escapeHtml(matricula)}</strong>
          ${getStatusBadge(r.estado)}
        </div>
        <div class="repair-item-meta" style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.25rem;">
          🚗 ${escapeHtml(marcaModelo)}
        </div>
        <div class="repair-item-meta" style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem;">
          👤 ${escapeHtml(clienteNome)}
        </div>
        <div class="repair-item-meta" style="color: var(--text-muted); font-size: 0.8rem; margin-bottom: 0.75rem;">
          📅 ${formatDate(r.dataInicio)}
        </div>
        <button class="btn btn-primary btn-sm" style="width: 100%;" onclick="selectReparacao(${r.id})">
          ${isActive ? '👀 A Visualizar Detalhes' : '👀 Ver Detalhes / Iniciar Trabalho'}
        </button>
      </div>`;
  }).join('');
}

/* ── Select a repair ── */
async function selectReparacao(id) {
  // Stop timer if running on a different repair
  if (timerRunning && currentRepair?.id !== id) {
    stopTimer(false);
  }

  try {
    const repair = await api.getReparacao(id);
    currentRepair = repair;
    renderRepairList(); // refresh active state
    renderDetailPanel();
    await loadPecas('');
    
    // Auto-scroll to details panel on smaller screens
    if (window.innerWidth <= 768) {
      document.getElementById('detail-panel')?.scrollIntoView({ behavior: 'smooth' });
    }
  } catch (err) {
    showToast('Erro ao carregar reparação: ' + err.message, 'error');
  }
}

