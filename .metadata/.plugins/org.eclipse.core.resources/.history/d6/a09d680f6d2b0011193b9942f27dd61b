/* ── Render operations ── */
function renderOperacoes(operacoes) {
  if (!operacoes.length) {
    return `<p class="text-muted" style="text-align:center; padding:.75rem">Sem operações registadas. Adicione uma para começar.</p>`;
  }
  return operacoes.map(op => `
    <div class="op-item" style="margin-bottom:.5rem; ${currentOpId === op.id ? 'border-left: 4px solid var(--primary-color)' : ''}">
      <div class="op-info">
        <div class="op-desc">
          <strong>${escapeHtml(op.descricao)}</strong>
          ${currentOpId === op.id ? '<span style="font-size:0.75rem;color:var(--primary-color); margin-left: 0.5rem;">(⏱️ Cronómetro Vinculado)</span>' : ''}
        </div>
        <div class="op-meta" style="margin-top: 0.25rem;">
          ${op.tempoEstimadoMinutos ? '⏱ Est: ' + formatDuration(op.tempoEstimadoMinutos) : '⏱ Est: --'}
          | 
          ${op.tempoRealMinutos ? '<strong>Real: ' + formatDuration(op.tempoRealMinutos) + '</strong>' : 'Real: --'}
        </div>
      </div>
      <div style="display:flex; gap:.4rem; align-items:center">
        ${getStatusBadge(op.estado || 'PENDENTE')}
        <button class="btn btn-secondary btn-sm" onclick="openOpModal(${op.id})" title="Editar / Vincular Tempo">✏️ Editar</button>
        ${op.estado !== 'CONCLUIDA' ? `<button class="btn btn-success btn-sm" onclick="concluirOperacao(${op.id})" title="Marcar como Concluída">✅</button>` : ''}
      </div>
    </div>
  `).join('');
}

/* ── Checklist ── */
function getChecklistKey() {
  return `sgo_checklist_${currentRepair?.id || 'generic'}`;
}

function renderChecklist() {
  const saved = JSON.parse(localStorage.getItem(getChecklistKey()) || '{}');
  return CHECKLIST_ITEMS.map((item, i) => {
    const checked = saved[i] || false;
    return `
      <div class="checklist-item ${checked ? 'checked' : ''}" onclick="toggleChecklistItem(${i}, this)">
        <input type="checkbox" id="chk-${i}" ${checked ? 'checked' : ''} onchange="toggleChecklistItem(${i}, this.closest('.checklist-item'))">
        <label for="chk-${i}">${escapeHtml(item)}</label>
      </div>`;
  }).join('');
}

function toggleChecklistItem(index, itemEl) {
  const key   = getChecklistKey();
  const saved = JSON.parse(localStorage.getItem(key) || '{}');
  saved[index] = !saved[index];
  localStorage.setItem(key, JSON.stringify(saved));

  if (itemEl) {
    itemEl.classList.toggle('checked', saved[index]);
    const chk = itemEl.querySelector('input[type="checkbox"]');
    if (chk) chk.checked = saved[index];
  }
}

function clearChecklist() {
  localStorage.removeItem(getChecklistKey());
  const cl = document.getElementById('checklist');
  if (cl) cl.innerHTML = renderChecklist();
}

/* ── Stopwatch ── */
function startTimer() {
  if (timerRunning) return;
  if (!currentOpId) {
     showToast('Aviso: O tempo será contabilizado no ecrã, mas não está vinculado a nenhuma operação. Edite uma operação para a vincular.', 'warning');
  }
  timerRunning = true;
  timerInterval = setInterval(() => {
    timerSeconds++;
    const el = document.getElementById('stopwatch-display');
    if (el) el.textContent = formatStopwatch(timerSeconds);
  }, 1000);
  document.getElementById('btn-start')?.setAttribute('disabled', true);
  document.getElementById('btn-stop')?.removeAttribute('disabled');
}

function stopTimer(sendToBackend = true) {
  if (!timerRunning) return;
  clearInterval(timerInterval);
  timerRunning = false;
  document.getElementById('btn-start')?.removeAttribute('disabled');
  document.getElementById('btn-stop')?.setAttribute('disabled', true);

  if (sendToBackend && currentOpId && currentRepair) {
    const minutes = Math.ceil(timerSeconds / 60);
    const op = (currentRepair.operacoes || []).find(o => o.id === currentOpId);
    
    if (op && minutes > 0) {
      api.updateOperacao(currentRepair.id, currentOpId, { 
         descricao: op.descricao,
         tempoRealMinutos: minutes 
      })
      .then(async () => {
         showToast(`Tempo extra de ${formatDuration(minutes)} guardado na operação!`, 'success');
         currentRepair = await api.getReparacao(currentRepair.id);
         timerSeconds = 0; // Reset ao contador local pois já foi somado no backend
         renderDetailPanel();
      })
      .catch(err => showToast('Erro ao guardar tempo: ' + err.message, 'error'));
    } else {
      showToast('Tempo inferior a 1 minuto ou operação não encontrada. Não foi guardado.', 'info');
      timerSeconds = 0;
      const el = document.getElementById('stopwatch-display');
      if (el) el.textContent = formatStopwatch(0);
    }
  } else {
    timerSeconds = 0;
    const el = document.getElementById('stopwatch-display');
    if (el) el.textContent = formatStopwatch(0);
  }
}

function resetTimer() {
  stopTimer(false);
}

/* ── Peças ── */
async function loadPecas(search) {
  try {
    allPecas = await api.getPecas(search) || [];
    renderPecasTable(allPecas);
  } catch (err) {
    const tbody = document.getElementById('pecas-tbody');
    if (tbody) tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted">Erro ao carregar peças</td></tr>`;
  }
}

function filterPecas(search) {
  const filtered = search
    ? allPecas.filter(p =>
        p.referencia?.toLowerCase().includes(search.toLowerCase()) ||
        p.designacao?.toLowerCase().includes(search.toLowerCase()))
    : allPecas;
  renderPecasTable(filtered);
}

function renderPecasTable(pecas) {
  const tbody = document.getElementById('pecas-tbody');
  if (!tbody) return;
  if (!pecas.length) {
    tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted" style="padding:1rem">Nenhuma peça encontrada</td></tr>`;
    return;
  }
  tbody.innerHTML = pecas.map(p => {
    const lowStock = p.stockAtual <= p.stockMinimo;
    return `
      <tr>
        <td><code>${escapeHtml(p.referencia)}</code></td>
        <td>${escapeHtml(p.designacao)} ${lowStock ? '<span class="badge badge-danger">⚠️ Baixo</span>' : ''}</td>
        <td class="${lowStock ? 'stock-low' : 'stock-ok'}"><strong>${p.stockAtual}</strong></td>
        <td>
          <button class="btn btn-primary btn-sm" onclick="openRequisitar(${p.id}, '${escapeHtml(p.designacao)}', ${p.stockAtual})"
            ${p.stockAtual <= 0 ? 'disabled title="Sem stock"' : ''}>
            ➕ Requisitar
          </button>
        </td>
      </tr>`;
  }).join('');
}

/* ── Requisitar Peça ── */
function openRequisitar(pecaId, designacao, stock) {
  document.getElementById('req-peca-id').value   = pecaId;
  document.getElementById('req-peca-desc').textContent = `${designacao} (Stock Disponível: ${stock})`;
  document.getElementById('req-qty').value        = 1;
  document.getElementById('req-qty').max          = stock;
  document.getElementById('req-obs').value        = '';
  showModal('modal-requisitar');
}

async function submitRequisicao(e) {
  e.preventDefault();
  const pecaId = parseInt(document.getElementById('req-peca-id').value);
  const qty    = parseInt(document.getElementById('req-qty').value);
  const obs    = document.getElementById('req-obs').value.trim();

  if (!qty || qty < 1) { showToast('Quantidade inválida.', 'warning'); return; }

  try {
    await api.requisitarPeca(pecaId, {
      pecaId:        pecaId,
      quantidade:    qty,
      observacoes:   obs || null,
      reparacaoId:   currentRepair?.id,
    });
    showToast('Peça requisitada com sucesso para esta reparação!', 'success');
    hideModal('modal-requisitar');
    await loadPecas(''); // Reload stock
  } catch (err) {
    showToast('Erro ao requisitar peça: ' + err.message, 'error');
  }
}

/* ── Operations Modal ── */
function openOpModal(opId) {
  document.getElementById('modal-op-title').textContent = opId ? 'Editar Operação' : 'Nova Operação';
  document.getElementById('form-op').reset();
  document.getElementById('op-id').value = opId || '';

  if (opId && currentRepair) {
    const op = (currentRepair.operacoes || []).find(o => o.id === opId);
    if (op) {
      document.getElementById('op-descricao').value = op.descricao || '';
      document.getElementById('op-tempo').value     = op.tempoEstimadoMinutos || op.tempoEstimado || '';
      document.getElementById('op-estado').value    = op.estado || 'PENDENTE';
      
      // Vincular o cronómetro a esta operação (importante para guardar o tempo real)
      currentOpId = opId;
      renderDetailPanel(); // Faz reload para mostrar que o cronómetro agora está vinculado visualmente
    }
  } else {
      currentOpId = null; // Se for uma operação nova, remove o vínculo antigo
      renderDetailPanel();
  }
  showModal('modal-op');
}

async function submitOperacao(e) {
  e.preventDefault();
  if (!currentRepair) return;
  const id      = document.getElementById('op-id').value;
  const desc    = document.getElementById('op-descricao').value.trim();
  const tempo   = document.getElementById('op-tempo').value;
  const estado  = document.getElementById('op-estado').value;

  const payload = {
    descricao:      desc,
    tempoEstimadoMinutos:  tempo ? parseInt(tempo) : null,
    estado: estado,
  };

  try {
    if (id) {
      await api.updateOperacao(currentRepair.id, id, payload);
      showToast('Operação atualizada!', 'success');
    } else {
      await api.addOperacao(currentRepair.id, payload);
      showToast('Nova operação adicionada!', 'success');
    }
    hideModal('modal-op');
    // Refresh repair
    currentRepair = await api.getReparacao(currentRepair.id);
    renderDetailPanel();
  } catch (err) {
    showToast('Erro: ' + err.message, 'error');
  }
}

async function concluirOperacao(opId) {
  if (!currentRepair) return;
  const op = (currentRepair.operacoes || []).find(o => o.id === opId);
  if (!op) return;
  try {
    await api.updateOperacao(currentRepair.id, opId, { 
       descricao: op.descricao,
       estado: 'CONCLUIDA' 
    });
    showToast('Operação dada como concluída!', 'success');
    currentRepair = await api.getReparacao(currentRepair.id);
    renderDetailPanel();
  } catch (err) {
    showToast('Erro: ' + err.message, 'error');
  }
}

/* ── Concluir Reparação ── */
async function concluirReparacao() {
  if (!currentRepair) return;

  const ops       = currentRepair.operacoes || [];
  const pendentes = ops.filter(o => o.estado !== 'CONCLUIDA');

  if (pendentes.length > 0) {
    const ok = await confirmDialog(
      `Existem ${pendentes.length} operação(ões) que ainda não estão concluídas. Deseja fechar a reparação mesmo assim?`
    );
    if (!ok) return;
  } else {
    const ok = await confirmDialog('Confirma que o trabalho completo desta viatura foi concluído?');
    if (!ok) return;
  }

  // Se o relógio estiver a contar, para e tenta gravar antes de fechar a reparação
  if (timerRunning) stopTimer(true);

  try {
    await api.updateEstadoReparacao(currentRepair.id, 'CONCLUIDA');
    showToast('Reparação concluída e fechada com sucesso!', 'success');
    currentRepair.estado = 'CONCLUIDA';
    renderDetailPanel();
    await loadMyRepairs(); // Atualiza a lista da esquerda
  } catch (err) {
    showToast('Erro ao concluir: ' + err.message, 'error');
  }
}

async function updateEstado(estado) {
  if (!currentRepair) return;
  try {
    await api.updateEstadoReparacao(currentRepair.id, estado);
    showToast(`Estado da reparação alterado com sucesso!`, 'success');
    currentRepair = await api.getReparacao(currentRepair.id);
    renderDetailPanel();
    await loadMyRepairs();
  } catch (err) {
    showToast('Erro ao mudar estado: ' + err.message, 'error');
  }
}