/* ── Operações ── */
function renderOperacoes(operacoes) {
  if (!operacoes.length) return `<p class="text-muted" style="text-align:center; margin: 1rem 0;">Nenhuma operação registada. Adicione uma para começar.</p>`;
  
  return operacoes.map(op => `
    <div class="op-item" style="margin-bottom:.5rem; padding: 0.75rem; border: 1px solid var(--border-color); border-radius: 6px; display: flex; justify-content: space-between; align-items: center; background: var(--bg-color);">
      <div class="op-info">
        <div class="op-desc" style="font-weight: 500;">${escapeHtml(op.descricao)}</div>
        <div class="op-meta" style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.25rem;">
          ⏱ ${formatDuration(op.tempoEstimadoMinutos || op.tempoEstimado || 0)} 
          ${op.valor ? ' | ' + formatCurrency(op.valor) : ''}
        </div>
      </div>
      <div style="display:flex; gap:.4rem; align-items:center">
        ${getStatusBadge(op.estado || 'NAO_INICIADA')}
        <button class="btn btn-secondary btn-sm" onclick="openOpModal(${op.id})" title="Editar">✏️</button>
        ${op.estado !== 'CONCLUIDA' && op.estado !== 'CONCLUIDA_OP' ? `<button class="btn btn-success btn-sm" onclick="concluirOperacao(${op.id})" title="Marcar como Concluída">✅</button>` : ''}
      </div>
    </div>`).join('');
}

async function concluirOperacao(opId) {
  if (!currentRepair) return;
  try {
    // O backend de operações pode usar CONCLUIDA_OP ou CONCLUIDA
    await api.updateOperacao(currentRepair.id, opId, { estado: 'CONCLUIDA' });
    showToast('Operação concluída!', 'success');
    currentRepair = await api.getReparacao(currentRepair.id);
    renderDetailPanel();
  } catch (err) {
    showToast('Erro: ' + err.message, 'error');
  }
}

/* ── Checklist ── */
function getChecklistKey() { return `sgo_checklist_${currentRepair?.id || 'generic'}`; }

function renderChecklist() {
  const saved = JSON.parse(localStorage.getItem(getChecklistKey()) || '{}');
  return CHECKLIST_ITEMS.map((item, i) => {
    const checked = saved[i] || false;
    return `
      <div class="checklist-item ${checked ? 'checked' : ''}" onclick="toggleChecklistItem(${i}, this)" style="padding: 0.5rem; border: 1px solid var(--border-color); border-radius: 4px; cursor: pointer; display: flex; gap: 0.5rem; align-items: center; transition: all 0.2s;">
        <input type="checkbox" id="chk-${i}" ${checked ? 'checked' : ''} onchange="toggleChecklistItem(${i}, this.closest('.checklist-item'))" style="pointer-events: none;">
        <label for="chk-${i}" style="margin: 0; pointer-events: none; ${checked ? 'text-decoration: line-through; color: var(--text-muted);' : ''}">${escapeHtml(item)}</label>
      </div>`;
  }).join('');
}

function toggleChecklistItem(index, itemEl) {
  const key = getChecklistKey();
  const saved = JSON.parse(localStorage.getItem(key) || '{}');
  saved[index] = !saved[index];
  localStorage.setItem(key, JSON.stringify(saved));
  if (itemEl) {
    itemEl.classList.toggle('checked', saved[index]);
    const chk = itemEl.querySelector('input[type="checkbox"]');
    const label = itemEl.querySelector('label');
    if (chk) chk.checked = saved[index];
    if (label) {
      if(saved[index]){
          label.style.textDecoration = 'line-through';
          label.style.color = 'var(--text-muted)';
      } else {
          label.style.textDecoration = 'none';
          label.style.color = 'inherit';
      }
    }
  }
}

function clearChecklist() {
  localStorage.removeItem(getChecklistKey());
  const cl = document.getElementById('checklist');
  if (cl) cl.innerHTML = renderChecklist();
}

/* ── Stopwatch ── */
function startTimer() {
  if (timerRunning) return;
  timerRunning = true;
  timerInterval = setInterval(() => {
    timerSeconds++;
    const el = document.getElementById('stopwatch-display');
    if (el) el.textContent = formatStopwatch(timerSeconds);
  }, 1000);
  document.getElementById('btn-start')?.setAttribute('disabled', true);
  document.getElementById('btn-stop')?.removeAttribute('disabled');
}

function stopTimer(sendToBackend = true) {
  if (!timerRunning) return;
  clearInterval(timerInterval);
  timerRunning = false;
  document.getElementById('btn-start')?.removeAttribute('disabled');
  document.getElementById('btn-stop')?.setAttribute('disabled', true);
  if (sendToBackend && currentOpId && currentRepair) {
    const minutes = Math.ceil(timerSeconds / 60);
    api.updateOperacao(currentRepair.id, currentOpId, { tempoRealMinutos: minutes })
      .then(() => showToast(`Tempo registado: ${formatDuration(minutes)}`, 'success'))
      .catch(err => showToast('Erro ao guardar tempo: ' + err.message, 'error'));
  }
}

function resetTimer() { 
    stopTimer(false); 
    timerSeconds = 0; 
    const el = document.getElementById('stopwatch-display'); 
    if (el) el.textContent = formatStopwatch(0); 
}

/* ── Peças ── */
async function loadPecas(search) {
  try {
    allPecas = await api.getPecas(search) || [];
    renderPecasTable(allPecas);
  } catch {
    const tbody = document.getElementById('pecas-tbody');
    if (tbody) tbody.innerHTML = `<tr><td colspan="4" class="text-center text-danger">Erro ao carregar peças.</td></tr>`;
  }
}

function filterPecas(search) {
  if (!allPecas || !allPecas.length) return;
  const filtered = allPecas.filter(p => 
      (p.referencia && p.referencia.toLowerCase().includes(search.toLowerCase())) || 
      (p.designacao && p.designacao.toLowerCase().includes(search.toLowerCase()))
  );
  renderPecasTable(filtered);
}

function renderPecasTable(pecas) {
  const tbody = document.getElementById('pecas-tbody');
  if (!tbody) return;
  
  if(!pecas || !pecas.length){
     tbody.innerHTML = `<tr><td colspan="4" class="text-center text-muted">Nenhuma peça encontrada.</td></tr>`;
     return;
  }
  
  tbody.innerHTML = pecas.map(p => {
    const lowStock = p.stockAtual <= p.stockMinimo;
    return `
    <tr>
      <td><code>${escapeHtml(p.referencia)}</code></td>
      <td>${escapeHtml(p.designacao)}</td>
      <td>
        <span class="badge ${lowStock ? 'badge-danger' : 'badge-success'}">${p.stockAtual}</span>
      </td>
      <td>
        <button class="btn btn-primary btn-sm" onclick="openRequisitar(${p.id}, '${escapeHtml(p.designacao.replace(/'/g, "\\'"))}', ${p.stockAtual})" ${p.stockAtual <= 0 ? 'disabled title="Sem stock"' : ''}>
          Req
        </button>
      </td>
    </tr>`
  }).join('');
}

function openRequisitar(pecaId, desc, stock) {
  document.getElementById('req-peca-id').value = pecaId;
  document.getElementById('req-peca-desc').textContent = `${desc} (Stock Disponível: ${stock})`;
  document.getElementById('req-qty').value = 1;
  document.getElementById('req-qty').max = stock; // Não permite pedir mais do que o stock
  document.getElementById('req-obs').value = '';
  showModal('modal-requisitar');
}

async function submitRequisicao(e) {
  e.preventDefault();
  const qty = parseInt(document.getElementById('req-qty').value);
  if (qty <= 0 || isNaN(qty)) {
      showToast('Quantidade inválida', 'warning');
      return;
  }
  
  const data = { 
      pecaId: document.getElementById('req-peca-id').value, 
      quantidade: qty, 
      observacoes: document.getElementById('req-obs').value, 
      reparacaoId: currentRepair.id 
  };
  
  try {
    await api.requisitarPeca(data.pecaId, data);
    showToast('Peça requisitada com sucesso!', 'success');
    hideModal('modal-requisitar');
    await loadPecas(''); // Recarrega para ver stock atualizado
  } catch (err) { 
      showToast('Erro ao requisitar peça: ' + err.message, 'error'); 
  }
}

/* ── Modais de Operação ── */
function openOpModal(opId) {
  document.getElementById('modal-op-title').textContent = opId ? 'Editar Operação' : 'Nova Operação';
  document.getElementById('form-op').reset();
  document.getElementById('op-id').value = opId || '';
  
  if (opId && currentRepair && currentRepair.operacoes) {
    const op = currentRepair.operacoes.find(o => o.id === opId);
    if (op) {
      document.getElementById('op-descricao').value = op.descricao || '';
      document.getElementById('op-tempo').value = op.tempoEstimadoMinutos || op.tempoEstimado || '';
      document.getElementById('op-valor').value = op.valor || '';
      document.getElementById('op-estado').value = op.estado || 'NAO_INICIADA';
      currentOpId = opId;
    }
  }
  showModal('modal-op');
}

async function submitOperacao(e) {
  e.preventDefault();
  
  const tempo = document.getElementById('op-tempo').value;
  const valor = document.getElementById('op-valor').value;
  
  const payload = {
    descricao: document.getElementById('op-descricao').value,
    tempoEstimadoMinutos: tempo ? parseInt(tempo) : null,
    valor: valor ? parseFloat(valor) : null,
    estado: document.getElementById('op-estado').value
  };
  
  // Retrocompatibilidade caso o backend use "tempoEstimado" em vez de "tempoEstimadoMinutos"
  payload.tempoEstimado = payload.tempoEstimadoMinutos;
  
  const opId = document.getElementById('op-id').value;
  
  try {
    if (opId) {
        await api.updateOperacao(currentRepair.id, opId, payload);
    } else {
        await api.addOperacao(currentRepair.id, payload);
    }
    
    showToast('Operação guardada!', 'success');
    hideModal('modal-op');
    currentRepair = await api.getReparacao(currentRepair.id);
    renderDetailPanel();
  } catch (err) { 
      showToast('Erro: ' + err.message, 'error'); 
  }
}

/* ── Estado Global da Reparação ── */
async function updateEstado(estado) {
  try {
    await api.updateEstadoReparacao(currentRepair.id, estado);
    showToast('Estado da viatura atualizado!', 'success');
    currentRepair = await api.getReparacao(currentRepair.id);
    renderDetailPanel();
    await loadMyRepairs(); // Atualiza os KPIs e a tabela
  } catch (err) { 
      showToast('Erro: ' + err.message, 'error'); 
  }
}

async function concluirReparacao() {
  // Verifica se há operações não concluídas
  const ops = currentRepair.operacoes || [];
  const pendentes = ops.filter(o => o.estado !== 'CONCLUIDA' && o.estado !== 'CONCLUIDA_OP');
  
  let msg = 'Tem a certeza que deseja concluir este trabalho?';
  if (pendentes.length > 0) {
      msg = `Atenção: Existem ${pendentes.length} operação(ões) que ainda não foram marcadas como concluídas.\n\nDeseja forçar a conclusão do trabalho mesmo assim?`;
  }

  const ok = await confirmDialog(msg);
  if (!ok) return;
  
  if (timerRunning) stopTimer(true);
  await updateEstado('CONCLUIDA');
}