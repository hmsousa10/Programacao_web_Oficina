'use strict';

const CHECKLIST_ITEMS = [
  'Verificação de óleo', 'Verificação de travões', 'Verificação de suspensão',
  'Verificação de pneus', 'Diagnóstico eletrónico', 'Verificação de luzes',
  'Verificação de fluidos', 'Verificação de bateria',
];

let allRepairs      = [];
let currentRepair   = null;
let allPecas        = [];
let timerInterval   = null;
let timerSeconds    = 0;
let timerRunning    = false;
let currentOpId     = null; // Operação que está a ser cronometrada

document.addEventListener('DOMContentLoaded', async () => {
  if (!initProtectedPage(['MECHANIC', 'MANAGER'])) return;
  
  if (typeof initMobileSidebar === 'function') {
    initMobileSidebar(); // Ativa os 3 tracinhos para navegação
  }
  
  await loadMyRepairs();
});

/* ── Load mechanic's repairs & Update KPIs ── */
async function loadMyRepairs() {
  const user = getCurrentUser();
  const listEl = document.getElementById('repair-list'); 
  
  if (!user || !user.id) {
    if (listEl) listEl.innerHTML = `<tr><td colspan="6"><div class="alert alert-warning">Sessão inválida. Por favor, faça login novamente.</div></td></tr>`;
    showToast("ID do utilizador não encontrado.", "error");
    return;
  }
  
  const countEl = document.getElementById('repair-count');
  if (listEl) {
    listEl.innerHTML = `<tr><td colspan="6"><div class="loading-overlay" style="position:relative; height: 100px;"><div class="spinner"></div></div></td></tr>`;
  }

  try {
    const data = await api.getReparacoesMecanico(user.id);
    
    // O Backend usa EM_EXECUCAO ou EM_PROGRESSO dependendo da versão
    allRepairs = (data || []).filter(r => ['PENDENTE', 'EM_EXECUCAO', 'EM_PROGRESSO', 'AGUARDA_PECAS'].includes(r.estado));
    
    // 1. Atualizar contagem total na tabela
    if (countEl) countEl.textContent = `${allRepairs.length} Trabalhos`;

    // 2. Atualizar KPIs (Cartões no topo)
    const pendentes = allRepairs.filter(r => r.estado === 'PENDENTE').length;
    const progresso = allRepairs.filter(r => ['EM_EXECUCAO', 'EM_PROGRESSO'].includes(r.estado)).length;
    const pecas     = allRepairs.filter(r => r.estado === 'AGUARDA_PECAS').length;

    const elPendentes = document.getElementById('kpi-pendentes');
    const elProgresso = document.getElementById('kpi-progresso');
    const elPecas     = document.getElementById('kpi-pecas');

    if (elPendentes) elPendentes.textContent = pendentes;
    if (elProgresso) elProgresso.textContent = progresso;
    if (elPecas)     elPecas.textContent     = pecas;

    renderRepairList();
  } catch (err) {
    if (listEl) {
      listEl.innerHTML = `<tr><td colspan="6"><div class="alert alert-danger"><span class="alert-icon">❌</span> ${escapeHtml(err.message)}</div></td></tr>`;
    }
  }
}

/* ── Render Fila de Trabalho (Tabela) ── */
function renderRepairList() {
  const listEl = document.getElementById('repair-list');
  if (!listEl) return;

  if (!allRepairs.length) {
    listEl.innerHTML = `<tr><td colspan="6" style="text-align:center; padding: 2rem;">✅ Sem reparações atribuídas na fila de trabalho.</td></tr>`;
    return;
  }

  listEl.innerHTML = allRepairs.map(r => {
    const isActive = currentRepair?.id === r.id;
    return `
      <tr class="${isActive ? 'active-row' : ''}">
        <td><strong>${escapeHtml(r.viaturaMatricula || '#' + r.id)}</strong></td>
        <td>${escapeHtml(r.viaturaMarca || '—')} ${escapeHtml(r.viaturaModelo || '')}</td>
        <td>👤 ${escapeHtml(r.clienteNome || '—')}</td>
        <td>${formatDate(r.dataInicio || r.dataEntrada || '')}</td>
        <td>${getStatusBadge(r.estado)}</td>
        <td>
          <button class="btn btn-sm ${isActive ? 'btn-primary' : 'btn-secondary'}" onclick="selectReparacao(${r.id})">
            ${isActive ? '👁️ A Visualizar' : 'Ver Detalhes'}
          </button>
        </td>
      </tr>`;
  }).join('');
}

/* ── Select a repair ── */
async function selectReparacao(id) {
  if (timerRunning && currentRepair?.id !== id) stopTimer(false);
  try {
    currentRepair = await api.getReparacao(id);
    renderRepairList(); // Atualiza a tabela para destacar a linha ativa
    renderDetailPanel();
    await loadPecas('');
    
    // Fazer scroll automático para os detalhes em ecrãs pequenos
    if (window.innerWidth <= 1024) {
        document.getElementById('detail-panel')?.scrollIntoView({ behavior: 'smooth' });
    }
  } catch (err) {
    showToast('Erro ao carregar reparação: ' + err.message, 'error');
  }
}

